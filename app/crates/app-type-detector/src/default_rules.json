                { "kind": "content", "file": "pyproject.toml", "regex": "(?i)\"flask(?:\"|[><=!~])" },
                { "kind": "content", "file": "pyproject.toml", "regex": "(?i)\"django(?:\"|[><=!~])" },
                { "kind": "content", "file": "pyproject.toml", "regex": "python-telegram-bot" },
                { "kind": "content", "file": "pyproject.toml", "regex": "discord\\.py" },
                { "kind": "content", "file": "pyproject.toml", "regex": "slack[-_]bolt" },
                { "kind": "content", "file": "pyproject.toml", "regex": "(?i)\"click(?:\"|[><=!~])" },
                { "kind": "content", "file": "pyproject.toml", "regex": "(?i)\"typer(?:\"|[><=!~])" }
              ]
            }
          }
        ]
