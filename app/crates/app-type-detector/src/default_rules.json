{
  "schema_version": 1,
  "version": "0.1.0",
  "rules": [
    {
      "id": "unity-engine",
      "description": "Unity game engine project.",
      "when": {
        "kind": "all",
        "of": [
          { "kind": "file_exists", "path": "ProjectSettings/ProjectSettings.asset" },
          { "kind": "content", "file": "ProjectSettings/ProjectVersion.txt", "regex": "m_EditorVersion:\\s*(\\S+)" }
        ]
      },
      "payload": {
        "confidence_weight": 1.0,
        "contributions": [
          { "field": "app_type", "value": "game", "delta": 1.0 },
          { "field": "tech_stack.game.engines", "value": "unity" },
          { "field": "tech_stack.languages", "value": "csharp" },
          { "field": "tech_stack.build_systems", "value": "unity" },
          { "field": "tech_stack.package_managers", "value": "nuget" },
          { "field": "tech_stack.package_managers", "value": "unity_package_manager" },
          { "field": "tech_stack.runtimes", "value": "mono" },
          { "field": "tech_stack.game.physics_engines", "value": "physx" }
        ],
        "captures_into": {
          "from_file": "ProjectSettings/ProjectVersion.txt",
          "field": "tech_stack.game.engine_version"
        }
      }
    },
    {
      "id": "unity-urp-pipeline",
      "when": {
        "kind": "content",
        "file": "Packages/manifest.json",
        "regex": "com\\.unity\\.render-pipelines\\.universal"
      },
      "payload": {
        "confidence_weight": 0.6,
        "contributions": [
          { "field": "tech_stack.game.rendering_pipelines", "value": "urp" }
        ]
      }
    },
    {
      "id": "unity-hdrp-pipeline",
      "when": {
        "kind": "content",
        "file": "Packages/manifest.json",
        "regex": "com\\.unity\\.render-pipelines\\.high-definition"
      },
      "payload": {
        "confidence_weight": 0.6,
        "contributions": [
          { "field": "tech_stack.game.rendering_pipelines", "value": "hdrp" }
        ]
      }
    },
    {
      "id": "shaderlab-and-hlsl",
      "when": {
        "kind": "glob",
        "pattern": "Assets/**/*.shader"
      },
      "payload": {
        "confidence_weight": 0.4,
        "contributions": [
          { "field": "tech_stack.game.shader_languages", "value": "shaderlab" },
          { "field": "tech_stack.game.shader_languages", "value": "hlsl" },
          { "field": "tech_stack.languages", "value": "hlsl" },
          { "field": "tech_stack.languages", "value": "shaderlab" }
        ]
      }
    },
    {
      "id": "godot-engine",
      "when": { "kind": "file_exists", "path": "project.godot" },
