          { "field": "tech_stack.game.engines", "value": "godot" },
          { "field": "tech_stack.languages", "value": "gdscript" },
          { "field": "tech_stack.build_systems", "value": "godot" }
        ],
        "captures_into": {
          "from_file": "project.godot",
          "field": "tech_stack.game.engine_version"
        }
      }
    },
