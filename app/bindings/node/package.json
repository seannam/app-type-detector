{
  "name": "@indiecraft/app-type-detector",
  "version": "0.4.1",
  "description": "Classify any codebase: returns a typed DetectionReport (app_type, tech_stack, scorecard). Native N-API bindings, zero runtime dependencies.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seannam/app-type-detector.git",
    "directory": "app/bindings/node"
  },
  "homepage": "https://github.com/seannam/app-type-detector",
  "bugs": {
    "url": "https://github.com/seannam/app-type-detector/issues"
  },
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.js",
    "index.d.ts",
    "README.md",
    "app-type-detector.darwin-arm64.node",
    "app-type-detector.darwin-x64.node",
    "app-type-detector.linux-x64-gnu.node",
    "app-type-detector.linux-arm64-gnu.node",
    "app-type-detector.linux-x64-musl.node",
    "app-type-detector.win32-x64-msvc.node"
  ],
  "keywords": [
    "detector",
    "app-type",
    "tech-stack",
    "classifier",
    "codebase",
    "repo",
    "napi-rs"
  ],
  "engines": {
    "node": ">= 18"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "scripts": {
    "build": "napi build --platform --release --dts .napi-autogen.d.ts",
    "build:debug": "napi build --platform --dts .napi-autogen.d.ts",
    "test": "vitest run"
  },
  "napi": {
    "name": "app-type-detector"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.4",
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  }
}
