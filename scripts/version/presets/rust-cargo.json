{
  "name": "rust-cargo",
  "description": "Rust binaries, libraries, and daemons: Cargo.toml. Uses cargo set-version if cargo-edit installed, else TOML edit.",
  "version": "1.0.0",
  "extends": null,
  "core": true,
  "detect": {
    "any_of": [
      "Cargo.toml"
    ],
    "none_of": [
      "package.json",
      "pyproject.toml"
    ]
  },
  "sync_targets": [
    {
      "path": "{app_root}/Cargo.toml",
      "type": "toml",
      "selector": "package.version",
      "primary": true
    },
    {
      "path": "VERSION",
      "type": "plain",
      "optional": false
    },
    {
      "path": "{app_root}/bindings/node/package.json",
      "type": "json",
      "selector": "version",
      "optional": true
    },
    {
      "path": "{app_root}/bindings/node/npm/linux-x64-gnu/package.json",
      "type": "json",
      "selector": "version",
      "optional": true
    },
    {
      "path": "{app_root}/bindings/node/npm/linux-arm64-gnu/package.json",
      "type": "json",
      "selector": "version",
      "optional": true
    },
    {
      "path": "{app_root}/bindings/node/npm/linux-x64-musl/package.json",
      "type": "json",
      "selector": "version",
      "optional": true
    },
    {
      "path": "{app_root}/bindings/node/npm/darwin-x64/package.json",
      "type": "json",
      "selector": "version",
      "optional": true
    },
    {
      "path": "{app_root}/bindings/node/npm/darwin-arm64/package.json",
      "type": "json",
      "selector": "version",
      "optional": true
    },
    {
      "path": "{app_root}/bindings/node/npm/win32-x64-msvc/package.json",
      "type": "json",
      "selector": "version",
      "optional": true
    },
    {
      "path": "{app_root}/bindings/node/package.json",
      "type": "native",
      "command": "f=\"${APP_ROOT:-.}/bindings/node/package.json\"; if [ -f \"$f\" ]; then tmp=$(mktemp) && jq --arg v {version} '.optionalDependencies |= with_entries(.value = $v)' \"$f\" > \"$tmp\" && mv \"$tmp\" \"$f\"; fi",
      "optional": true
    }
  ],
  "changelog": {
    "tool": "release-please",
    "file": "CHANGELOG.md"
  },
  "ci": {
    "tool": "release-please",
    "workflow_template": "auto-release-on-push"
  },
  "ui": {
    "integration_note": "Rust has the `env!(\"CARGO_PKG_VERSION\")` macro which reads Cargo.toml at compile time. This is the idiomatic choice for binaries, daemons, and menu bar apps. For CLIs, clap exposes it automatically via #[command(version)].",
    "snippets": {
      "const": "pub const APP_VERSION: &str = env!(\"CARGO_PKG_VERSION\");",
      "clap": "#[derive(Parser)]\n#[command(version, about)]\nstruct Cli { /* ... */ }",
      "daemon-log": "tracing::info!(version = env!(\"CARGO_PKG_VERSION\"), \"starting daemon\");",
      "axum-endpoint": "async fn version_handler() -> &'static str { env!(\"CARGO_PKG_VERSION\") }"
    }
  },
  "release": {
    "tag_format": "v{major}.{minor}.{patch}",
    "prerelease_patterns": [
      "v*-rc*",
      "v*-beta*",
      "v*-alpha*"
    ]
  },
  "mode": "auto"
}
